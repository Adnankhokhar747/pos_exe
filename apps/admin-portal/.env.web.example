# Web deployment — copy to .env.production.local before building.
#
# VITE_ADMIN_BASE   → the path where the admin portal is served (must end with /)
# VITE_API_BASE_URL → your PHP backend URL (no trailing slash)
#
# After building, copy apps/admin-portal/dist/* into backend/api/public/admin/
# Then visit https://yourserver.com/admin/ to reach the Super Admin login page.

VITE_ADMIN_BASE=/admin/
VITE_API_BASE_URL=https://api.yourserver.com
