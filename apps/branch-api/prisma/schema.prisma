// Branch-local schema — Phase 0/1 slice of docs/01-database-design.md.
// Covers: Identity, Catalog, Inventory, Sales contexts needed for the single-store POS MVP
// (see docs/13-development-roadmap.md Phase 1). Purchasing, Customers, Accounting Lite,
// Multi-Currency, Plugins, and the cloud-owned Licensing tables follow in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Identity & Tenancy ----------

model Tenant {
  id           String   @id @default(uuid())
  name         String
  baseCurrency String   @default("USD") @map("base_currency")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  branches Branch[]
  users    User[]
  roles    Role[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  code      String
  timezone  String   @default("UTC")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  warehouses Warehouse[]
  invoices   Invoice[]

  @@unique([tenantId, code])
  @@map("branches")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  fullName     String   @map("full_name")
  username     String
  email        String?
  pinHash      String?  @map("pin_hash")
  passwordHash String?  @map("password_hash")
  status       String   @default("active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]

  @@unique([tenantId, username])
  @@map("users")
}

model Role {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  isSystemRole Boolean  @default(false) @map("is_system_role")

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String @id @default(uuid())
  code        String @unique
  module      String
  description String

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

// ---------- Catalog ----------

model Category {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  parentId  String?  @map("parent_id")
  name      String
  sortOrder Int      @default(0) @map("sort_order")

  products Product[]

  @@map("categories")
}

model Product {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  sku          String
  barcode      String?
  name         String
  description  String?
  categoryId   String?  @map("category_id")
  costPrice    Decimal  @default(0) @map("cost_price") @db.Decimal(14, 4)
  salePrice    Decimal  @map("sale_price") @db.Decimal(14, 4)
  taxRatePct   Decimal  @default(0) @map("tax_rate_pct") @db.Decimal(6, 3)
  reorderLevel Decimal  @default(0) @map("reorder_level") @db.Decimal(14, 4)
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  category     Category?     @relation(fields: [categoryId], references: [id])
  stockLevels  StockLevel[]
  stockLedger  StockLedgerEntry[]
  invoiceLines InvoiceLine[]

  @@unique([tenantId, sku])
  @@index([tenantId, barcode])
  @@map("products")
}

// ---------- Inventory ----------

model Warehouse {
  id        String  @id @default(uuid())
  branchId  String  @map("branch_id")
  name      String
  isDefault Boolean @default(true) @map("is_default")

  branch      Branch             @relation(fields: [branchId], references: [id])
  stockLevels StockLevel[]
  ledger      StockLedgerEntry[]

  @@map("warehouses")
}

model StockLevel {
  warehouseId      String  @map("warehouse_id")
  productId        String  @map("product_id")
  quantityOnHand   Decimal @default(0) @map("quantity_on_hand") @db.Decimal(14, 4)
  quantityReserved Decimal @default(0) @map("quantity_reserved") @db.Decimal(14, 4)

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@id([warehouseId, productId])
  @@map("stock_levels")
}

enum StockMovementType {
  purchase_receipt
  sale
  sale_return
  adjustment
  opening_balance
}

model StockLedgerEntry {
  id              String            @id @default(uuid())
  warehouseId     String            @map("warehouse_id")
  productId       String            @map("product_id")
  movementType    StockMovementType @map("movement_type")
  quantityDelta   Decimal           @map("quantity_delta") @db.Decimal(14, 4)
  unitCostAtMove  Decimal           @default(0) @map("unit_cost_at_movement") @db.Decimal(14, 4)
  referenceTable  String?           @map("reference_table")
  referenceId     String?           @map("reference_id")
  occurredAt      DateTime          @default(now()) @map("occurred_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([productId, warehouseId, occurredAt])
  @@map("stock_ledger")
}

// ---------- Sales / POS ----------

enum InvoiceStatus {
  held
  completed
  voided
}

model Invoice {
  id           String        @id @default(uuid())
  branchId     String        @map("branch_id")
  invoiceNo    String        @map("invoice_no")
  status       InvoiceStatus @default(completed)
  subtotal     Decimal       @default(0) @db.Decimal(14, 4)
  discountTotal Decimal      @default(0) @map("discount_total") @db.Decimal(14, 4)
  taxTotal     Decimal       @default(0) @map("tax_total") @db.Decimal(14, 4)
  grandTotal   Decimal       @default(0) @map("grand_total") @db.Decimal(14, 4)
  cashierId    String?       @map("cashier_id")
  voidReason   String?       @map("void_reason")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  branch   Branch        @relation(fields: [branchId], references: [id])
  lines    InvoiceLine[]
  payments Payment[]

  @@unique([branchId, invoiceNo])
  @@index([branchId, status, createdAt])
  @@map("invoices")
}

model InvoiceLine {
  id            String  @id @default(uuid())
  invoiceId     String  @map("invoice_id")
  productId     String  @map("product_id")
  quantity      Decimal @db.Decimal(14, 4)
  unitPrice     Decimal @map("unit_price") @db.Decimal(14, 4)
  discountValue Decimal @default(0) @map("discount_value") @db.Decimal(14, 4)
  taxAmount     Decimal @default(0) @map("tax_amount") @db.Decimal(14, 4)
  lineTotal     Decimal @map("line_total") @db.Decimal(14, 4)

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("invoice_lines")
}

enum PaymentMethod {
  cash
  debit_card
  credit_card
  bank_transfer
  mobile_wallet
  credit_sale
}

model Payment {
  id             String        @id @default(uuid())
  invoiceId      String        @map("invoice_id")
  method         PaymentMethod
  amount         Decimal       @db.Decimal(14, 4)
  receivedAmount Decimal?      @map("received_amount") @db.Decimal(14, 4)
  changeAmount   Decimal?      @map("change_amount") @db.Decimal(14, 4)
  reference      String?

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}
