# Web deployment: copy this to .env.production.local and set your server URL.
# When VITE_API_BASE_URL is set, the renderer connects to your remote PHP backend
# instead of the local Electron API (http://127.0.0.1:4000).
#
# Build for web:  npm run build  (inside apps/renderer/)
# Serve the dist/ folder from any static host (Nginx, Apache, S3, etc.).
# The PHP backend (backend/api/) must be accessible at the URL below.

VITE_API_BASE_URL=https://api.yourserver.com
